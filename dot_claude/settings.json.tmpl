{
  "cleanupPeriodDays": 3650,
  "env": {
    "CLAUDE_BASH_MAINTAIN_PROJECT_WORKING_DIR": "true",
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1",
    "CLAUDE_CODE_MAX_OUTPUT_TOKENS": "64000"
  },
  "includeCoAuthoredBy": false,
  "permissions": {
    "allow": [
      "WebSearch",
      "WebFetch(domain:support.atlassian.com)",
      "Bash(claude-code config:*)",
      "Bash(node --version)",
{{- if eq .machine_type "work" }}
      "WebFetch(domain:coreweave.atlassian.net)",
{{- end }}
      "Bash(git clone:*)",
      "Bash(mkdir:*)",
      "Bash(go:*)",
      "Write(*)",
      "Bash(ls:*)",
      "Bash(git:*)",
      "Update(*:*)",
      "Bash(mv:*)",
      "Bash(echo:*)",
      "Bash(sed:*)",
      "Bash(source:*)",
      "Bash(head:*)",
      "Bash(tail:*)",
      "Bash(npm:*)",
      "Bash(npx:*)",
      "Bash(pkill:*)",
      "Bash(touch:*)",
      "Bash(grep:*)",
      "Bash(deadcode:*)",
      "Bash(sqlite3:*)",
      "Bash(curl:*)",
      "Bash(rg:*)",
      "Bash(chmod:*)",
      "Bash(lsof:*)",
      "Bash(make:*)",
      "Bash(PORT=:*)",
      "Bash(find:*)",
      "Bash(docker:*)",
      "Bash(poetry:*)",
      "Bash(python:*)",
      "Bash(python3:*)",
      "Update(*)",
{{- if eq .machine_type "work" }}
      "mcp__glean_default__search",
      "mcp__glean_default__read_document",
      "mcp__glean_default__chat",
      "mcp__glean_default__code_search",
      "mcp__glean_default__employee_search",
{{- end }}
      "mcp__sg__sg_keyword_search",
      "mcp__sg__sg_nls_search",
      "mcp__sg__sg_read_file",
      "mcp__sg__sg_list_files",
      "mcp__sg__sg_list_repos",
      "mcp__sg__sg_diff_search",
      "mcp__sg__sg_find_references",
      "mcp__sg__sg_go_to_definition",
      "mcp__sg__sg_deepsearch_read",
      "mcp__sg__sg_commit_search"
    ],
    "deny": [
      "Read(.env)",
      "Read(.env.*)",
      "Read(~/.aws/**)",
      "Read(~/.ssh/**)",
      "Read(~/.kube/config)",
      "Read(~/.docker/config.json)",
      "Read(~/.vault-token)",
      "Read(./secrets/**)",
      "Edit(.env)",
      "Edit(.env.*)",
      "Edit(~/.aws/**)",
      "Edit(~/.ssh/**)"
    ],
    "defaultMode": "default"
  },
  "model": "opus[1m]",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/git-safety.sh"
          }
        ]
      }
    ]
  },
  "enabledPlugins": {
    "claude-code-setup@claude-plugins-official": true,
    "claude-md-management@claude-plugins-official": true,
    "code-review@claude-code-plugins": true,
    "feature-dev@claude-code-plugins": true,
    "gopls-lsp@claude-plugins-official": true,
    "pr-review-toolkit@claude-code-plugins": true,
    "superpowers@claude-plugins-official": true,
    "skill-creator@claude-plugins-official": true,
{{- if eq .machine_type "work" }}
    "deep-review@cw-claude-code-plugins": true,
{{- end }}
    "swift-lsp@claude-plugins-official": true,
    "visual-explainer@visual-explainer-marketplace": true,
    "plannotator@plannotator": true
  },
  "extraKnownMarketplaces": {
{{- if eq .machine_type "work" }}
    "cw-claude-code-plugins": {
      "source": {
        "source": "github",
        "repo": "coreweave/agent-plugins"
      }
    },
{{- end }}
    "visual-explainer-marketplace": {
      "source": {
        "source": "github",
        "repo": "nicobailon/visual-explainer"
      }
    },
    "plannotator": {
      "source": {
        "source": "github",
        "repo": "backnotprop/plannotator"
      }
    }
  },
  "sandbox": {
    "enabled": true,
    "autoAllowBashIfSandboxed": true
  },
  "alwaysThinkingEnabled": true,
  "effortLevel": "high",
  "skipDangerousModePermissionPrompt": true,
  "statusLine": {
    "type": "command",
    "command": "npx -y ccstatusline@latest",
    "padding": 0
  }
}