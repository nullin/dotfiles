{{- $machineType := promptChoiceOnce . "machine_type" "Machine type" (list "work" "personal") -}}
{{- $name := promptStringOnce . "name" "Full name" -}}
{{- $email := promptStringOnce . "email" "Email (for git)" -}}
{{- $githubUsername := promptStringOnce . "github_username" "GitHub username" -}}
{{- $goprivate := "" -}}
{{- $corporatePath := "" -}}
{{- if eq $machineType "work" -}}
{{-   $goprivate = promptStringOnce . "goprivate" "GOPRIVATE (e.g. github.com/org/*)" -}}
{{-   $corporatePath = promptStringOnce . "corporate_path" "Corporate bin path (e.g. /opt/company/bin)" -}}
{{- end -}}

[git]
    autoCommit = true
    autoPush = true

[data]
    machine_type = {{ $machineType | quote }}
    name = {{ $name | quote }}
    email = {{ $email | quote }}
    github_username = {{ $githubUsername | quote }}
    username = {{ .chezmoi.username | quote }}
    goprivate = {{ $goprivate | quote }}
    corporate_path = {{ $corporatePath | quote }}
